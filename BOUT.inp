################################################################
# Electrons

[e]
# Set electron density from quasineutrality,
# and parallel flow from ion flow, assuming no currents
type = quasineutral, evolve_pressure, zero_current, anomalous_diffusion

AA = 1/1836
charge = -1

thermal_conduction = true
kappa_limit_alpha = 0.2
conduction_collisions_mode = braginskii

anomalous_D = `d+`:anomalous_D  # Same as ions
anomalous_chi = 0.2  # Electron thermal diffusion
diagnose = true  # Save additional diagnostics

[Pe]
function = initial_pe
bndry_xin = dirichlet(core_pe)
bndry_xout = dirichlet(peak_pe)
#bndry_sol = decaylength(30)
#bndry_pfr = decaylength(30)
#bndry_all = dirichlet(peak_pe)  # All other boundaries

